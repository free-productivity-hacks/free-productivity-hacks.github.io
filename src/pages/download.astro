---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Download Your Free Guide — Productivity Hacks">
  <!-- Download Section -->
  <main class="download-page">
    <div class="download-wrapper">

      <!-- Book Image -->
      <div class="book-showcase">
        <div class="book-glow"></div>
        <div class="book-image-wrapper">
          <!-- Placeholder book cover image — replace src with your actual ebook cover -->
          <img src="/assets/productivity-hacks-2026.webp"
            alt="Productivity Hacks 2026 Edition — Free Ebook Cover" width="560" height="800" id="book-cover-image" />
        </div>
      </div>

      <!-- Thank You Content -->
      <div class="download-content">
        <div class="download-badge">
          <span class="check">✓</span>
          You're all set!
        </div>
        <h1>
          Thank You for<br />
          <span class="gradient-text">Choosing to Level Up!</span>
        </h1>
        <p class="thank-you-text">
          Your free copy of <em>Productivity Hacks</em> is ready. Click the button below to download the ebook instantly
          — no sign-ups, no strings attached. Start mastering your time today.
        </p>
        <div class="download-actions">
          <a href="#" class="btn btn-primary" id="download-now-btn">
            <span class="btn-icon">⬇</span>
            Download Now — It's Free
          </a>
          <a href="/"
            class="btn btn-secondary">
            ← Back to Home
          </a>
        </div>
      </div>

    </div>
  </main>

  <!-- Footer -->
  
<script is:inline>
    document.getElementById('download-now-btn').addEventListener('click', function (e) {
      e.preventDefault();

      var btn = this;
      var originalHTML = btn.innerHTML;

      // Change to loading state
      btn.innerHTML = '<span class="btn-icon spinner">↻</span> Preparing...';
      btn.style.pointerEvents = 'none';
      btn.style.opacity = '0.8';

      // First open up the Monetag link in a new tab
      window.open('https://omg10.com/4/10733234', '_blank');

      // After 3 seconds, open the Google Drive link
      setTimeout(function () {
        // Restore button state
        btn.innerHTML = originalHTML;
        btn.style.pointerEvents = 'auto';
        btn.style.opacity = '1';

        // Attempt to open in a new tab. If blocked by popup blocker, fall back to navigating the current tab.
        var newTab = window.open('/assets/ProductivityHacks.pdf', '_blank');
        if (!newTab) {
          window.location.href = '/assets/ProductivityHacks.pdf';
        }
      }, 3000);
    });
  </script>
</Layout>
