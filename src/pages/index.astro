---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Productivity Hacks — Free Guide to Mastering Your Time">
  <!-- Hero -->
  <header class="hero" id="hero">
    <div class="container">
      <div class="hero-badge">
        <span class="dot"></span>
        Free Download — 2026 Productivity Hacks
      </div>
      <h1>
        Stop Busy-Work and Start Growing:<br />
        <span class="gradient-text">Master Your Productivity Today!</span>
      </h1>
      <p class="hero-sub">
        Unlock the ultimate guide to reclaiming your time, boosting efficiency, and achieving long-term success in a
        competitive market. Get your free copy of <em>Productivity Hacks</em> and transform how you work.
      </p>
      <p class="hero-body">
        Are you feeling overwhelmed by endless to-do lists and projects that never seem to finish? Most businesses face
        the same challenges: time management, content creation, and customer engagement.
      </p>
      <div class="hero-actions">
        <a href="/download"  class="btn btn-primary"
          id="hero-download-btn">
          <span class="btn-icon">⬇</span>
          Download Your Free Guide Now
        </a>
      </div>
    </div>
  </header>

  <!-- What's Inside -->
  <section class="section" id="features">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label"><span class="line"></span> What's Inside</span>
        <h2 class="section-title">Practical Strategies That Actually Work</h2>
        <p class="section-desc">
          Our comprehensive report provides practical, easy-to-implement strategies designed to inspire innovative
          thinking and maximize your growth potential.
        </p>
      </div>

      <div class="features-grid">
        <!-- Card 1 -->
        <div class="feature-card reveal" id="feature-prioritize">
          <div class="feature-icon">🎯</div>
          <h3>Prioritize Like a Pro</h3>
          <p>Use the Eisenhower Matrix to categorize tasks by urgency and importance, so you always know what to tackle
            first.</p>
        </div>

        <!-- Card 2 -->
        <div class="feature-card reveal" id="feature-conquer">
          <div class="feature-icon">🧩</div>
          <h3>Conquer Large Projects</h3>
          <p>Learn how to break daunting tasks into manageable, stress-reducing steps that build momentum and
            confidence.</p>
        </div>

        <!-- Card 3 -->
        <div class="feature-card reveal" id="feature-clarity">
          <div class="feature-icon">🌅</div>
          <h3>Start with Clarity</h3>
          <p>Discover why setting daily goals the night before reduces morning decision fatigue and sets you up for
            success.</p>
        </div>

        <!-- Card 4 -->
        <div class="feature-card reveal" id="feature-focus">
          <div class="feature-icon">🍅</div>
          <h3>Master Your Focus</h3>
          <p>Use the Pomodoro Technique to maintain high concentration and beat procrastination with timed work sprints.
          </p>
        </div>

        <!-- Card 5 -->
        <div class="feature-card reveal" id="feature-eliminate">
          <div class="feature-icon">⚡</div>
          <h3>Eliminate Time-Drains</h3>
          <p>Learn the secrets of task batching and holding lean, essential-only meetings to reclaim hours every week.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner" id="download">
    <div class="container">
      <div class="cta-inner reveal">
        <h2>Ready to Transform How You Work?</h2>
        <p>From mastering the Eisenhower Matrix to leveraging the Pomodoro Technique, you'll learn how to focus on what
          truly matters.</p>
        <a href="/download"  class="btn btn-primary"
          id="cta-download-btn">
          <span class="btn-icon">⬇</span>
          Download Your Free Guide Now
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label"><span class="line"></span> FAQ</span>
        <h2 class="section-title">Frequently Asked Questions</h2>
        <p class="section-desc">Everything you need to know about the Productivity Hacks guide.</p>
      </div>

      <div class="faq-list reveal">
        <!-- Q1 -->
        <div class="faq-item" id="faq-1">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-1">
            Who is this book for?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer" id="faq-answer-1" role="region">
            <div class="faq-answer-inner">
              <em>Productivity Hacks</em> is designed for businesses and professionals facing common challenges like
              time management, brand building, and customer engagement. It serves as a practical resource for anyone
              looking to improve efficiency and achieve long-term success.
            </div>
          </div>
        </div>

        <!-- Q2 -->
        <div class="faq-item" id="faq-2">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-2">
            What kind of "hacks" are included?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer" id="faq-answer-2" role="region">
            <div class="faq-answer-inner">
              The guide offers a diverse range of tips, including time management frameworks like the Eisenhower Matrix
              and Pomodoro Technique, strategies for breaking down large projects, and methods for reducing workplace
              distractions like unnecessary meetings.
            </div>
          </div>
        </div>

        <!-- Q3 -->
        <div class="faq-item" id="faq-3">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-3">
            I'm always overwhelmed by large projects. Does this book help with that?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer" id="faq-answer-3" role="region">
            <div class="faq-answer-inner">
              Yes! The guide specifically teaches you how to divide large projects—like "launching a marketing
              campaign"—into smaller milestones such as brainstorming, designing, and scheduling. This approach helps
              build momentum and reduces stress.
            </div>
          </div>
        </div>

        <!-- Q4 -->
        <div class="faq-item" id="faq-4">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-4">
            Will these strategies really save me time?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer" id="faq-answer-4" role="region">
            <div class="faq-answer-inner">
              Absolutely. By implementing techniques such as task batching (grouping similar tasks like emails or calls)
              and using timers to track task durations, you can reduce context switching and prevent over-investing in
              low-priority activities.
            </div>
          </div>
        </div>

        <!-- Q5 -->
        <div class="faq-item" id="faq-5">
          <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-5">
            How do I get my copy?
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-answer" id="faq-answer-5" role="region">
            <div class="faq-answer-inner">
              You can download the full <em>Productivity Hacks</em> guide for free by clicking the download button on
              this page!
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  
</Layout>
