---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Productivity Blog — Tips, Strategies & Frameworks">
  <!-- Page Header -->
  <header class="page-header" id="page-header">
    <div class="container">
      <div class="page-header-badge">
        <span class="dot"></span>
        3 Articles &amp; Growing
      </div>
      <h1>
        The <span class="gradient-text">Productivity</span> Blog
      </h1>
      <p class="page-header-sub">
        Actionable strategies, proven frameworks, and fresh perspectives to help you work smarter — not harder.
      </p>
    </div>
  </header>

  <!-- Blog Posts Grid -->
  <section class="blog-section">
    <div class="container">
      <div class="blog-grid">

        <a href="/decision-fatigue" 
          class="blog-card reveal" id="post-decision-fatigue">
          <span class="blog-card-category">💡 Mindset</span>
          <h2>Decision Fatigue: Why You're Tired Before the Day Begins</h2>
          <p class="blog-card-excerpt">
            Discover what decision fatigue is, how it drains your energy, and actionable strategies to overcome it.
            Learn why you feel so tired and how to reclaim your mental energy.
          </p>
          <div class="blog-card-footer">
            <span class="blog-card-meta">🕐 6 min read</span>
            <span class="blog-card-read-more">Read More →</span>
          </div>
        </a>

        <a href="/eisenhower-matrix" 
          class="blog-card reveal" id="post-eisenhower">
          <span class="blog-card-category">🎯 Time Management</span>
          <h2>The Eisenhower Matrix: How to Prioritize What Truly Matters</h2>
          <p class="blog-card-excerpt">
            Discover what decision fatigue is, how it drains your energy, and actionable strategies to overcome it.
            Learn why you feel so tired and how to reclaim your mental energy.
          </p>
          <div class="blog-card-footer">
            <span class="blog-card-meta">🕐 5 min read</span>
            <span class="blog-card-read-more">Read More →</span>
          </div>
        </a>

        <a href="/project-paralysis" 
          class="blog-card reveal" id="post-project-paralysis">
          <span class="blog-card-category"> 🧠 Focus</span>
          <h2>Project Paralysis: How to Stop Overthinking and Start Doing</h2>
          <p class="blog-card-excerpt">
            Discover what decision fatigue is, how it drains your energy, and actionable strategies to overcome it.
            Learn why you feel so tired and how to reclaim your mental energy.
          </p>
          <div class="blog-card-footer">
            <span class="blog-card-meta">🕐 7 min read</span>
            <span class="blog-card-read-more">Read More →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Footer -->
  
</Layout>
