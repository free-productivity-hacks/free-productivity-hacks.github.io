---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Productivity Hacks">
  <!-- Page Header -->
  <header class="page-header" id="page-header">
    <div class="container">
      <div class="page-header-badge">
        <span class="dot"></span>
        Our Story
      </div>
      <h1>
        About <span class="gradient-text">Productivity Hacks</span>
      </h1>
      <p class="page-header-sub">
        We believe that everyone deserves access to the tools and strategies that drive real results — without the hefty
        price tag.
      </p>
    </div>
  </header>

  <!-- Our Mission -->
  <section class="section" id="mission">
    <div class="container">
      <div class="about-prose reveal">
        <span class="section-label"><span class="line"></span> Our Mission</span>
        <h2 class="section-title">Empowering You to Work Smarter</h2>
        <p>
          Productivity Pulse was founded in 2026 to solve a simple frustration: most professional development advice is
          either too vague to be useful or locked behind an expensive paywall. We set out to change that by curating a
          <strong>comprehensive, no-fluff productivity hacks guide</strong> packed with proven frameworks—and making it
          accessible to
          everyone.
        </p>
        <p>
          Our resource distills insights from leading methodologies—including the <strong>Eisenhower Matrix</strong>,
          the
          <strong>Pomodoro
            Technique</strong>, and <strong>Deep Work protocols</strong>—into easy-to-implement steps. Whether you're a
          remote
          professional, a solo
          entrepreneur, or a student, these strategies are designed to help you reclaim your time.
        </p>
      </div>
    </div>
  </section>

  <!-- Value Cards -->
  <section class="section" id="values" style="padding-top:0;">
    <div class="container">
      <div class="about-grid">

        <div class="about-card reveal">
          <div class="about-icon">🎯</div>
          <h3>Practical Over Theoretical</h3>
          <p>Every strategy in our free PDF guide has been vetted for real-world scenarios. We skip the jargon and give
            you steps you can implement in your next work session.</p>
        </div>

        <div class="about-card reveal">
          <div class="about-icon">🆓</div>
          <h3>Open Access Resource</h3>
          <p>We believe great productivity advice shouldn't be a luxury. Our guide is provided as a free resource,
            supported by our digital partners to keep it accessible to all.</p>
        </div>

        <div class="about-card reveal">
          <div class="about-icon">🚀</div>
          <h3>2026 Results-Driven</h3>
          <p>From <strong>AI-driven scheduling</strong> to energy management, every hack is updated for the modern,
            digital-first
            workspace.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="container">
      <div class="cta-inner reveal">
        <h2>Ready to Transform Your Workflow?</h2>
        <p>Join thousands of professionals who are mastering their time. Download your free copy of the <strong>Ultimate
            Productivity Hacks Guide</strong> and start seeing measurable results today.</p>
        <a href="/download" 
          class="btn btn-primary" id="about-cta-btn">
          <span class="btn-icon">⬇</span>
          Get Your Free Guide
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  
</Layout>
